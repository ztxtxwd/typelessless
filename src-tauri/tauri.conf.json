{
  "$schema": "https://raw.githubusercontent.com/nicotsx/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Typelessless",
  "version": "0.1.5",
  "identifier": "com.typelessless.desktop",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "recorder",
        "title": "Typelessless",
        "url": "index.html",
        "width": 220,
        "height": 90,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "center": true,
        "shadow": false,
        "focus": false
      },
      {
        "label": "settings",
        "title": "Typelessless - Settings",
        "url": "settings.html",
        "width": 500,
        "height": 640,
        "visible": false,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "Entitlements.plist"
    }
  }
}
